/*
  Find K Rotation

  Pattern: Binary Search

  Same as Find Minimum in Rotated Array.

  Rotation count =
  Index of minimum element.

  Find sorted half.

  Store its minimum and index,
  then eliminate that half.

  If entire search space is sorted:
      Store arr[low] and low
      Break

  TC: O(log n)
  SC: O(1)
*/

class Solution {
  public:
    int findKRotation(vector<int> &arr) {
        // Code Here
        int low = 0, high = arr.size() - 1;
        int mini = INT_MAX, idx = 0;
        while(low <= high){
            int mid = low + (high - low) / 2;
            if(arr[low] <= arr[high]){
                if(arr[low] < mini){
                    mini = arr[low];
                    idx = low;
                }
                break;
            }
            else if(arr[low] <= arr[mid]){
                if(arr[low] < mini){
                    mini = arr[low];
                    idx = low;
                }
                low = mid + 1;
            }
            else{
                if(arr[mid] < mini){
                    mini = arr[mid];
                    idx = mid;
                }
                high = mid - 1;
            }
        }
        return idx;
    }
};
