/*
  Floor in a Sorted Array

  Pattern: Binary Search

  Floor - Largest element such that:

  arr[i] <= target

  If no such element exists:
  return -1

  If arr[mid] <= target:
      Store answer
      Search right half

  Else:
      Search left half

  TC: O(log n)
  SC: O(1)
*/

class Solution {
  public:
    int findFloor(vector<int>& arr, int x) {
        // code here
        int low = 0, high = arr.size() - 1;
        int ans = -1;
        while(low <= high){
            int mid = low + (high - low) / 2;
            if(arr[mid] <= x){
                ans = mid;
                low = mid +  1;
            }
            else high = mid - 1;
        }
        return ans;
    }
};
